# Open Source Scout Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API Key (Required)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=<your-groq-api-key-here>

# GitHub Token (Optional, but recommended)
# Without token: 60 requests/hour
# With token: 5000 requests/hour
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=<your-github-token-here>

# Neon Postgres (Required for signup/login)
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
NEON_DATABASE_URL=<your-neon-postgres-connection-string>

# Auth (Required for issuing JWTs)
# Use a long random string in production.
AUTH_JWT_SECRET=<your-jwt-secret>
