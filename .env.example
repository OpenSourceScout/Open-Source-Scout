# Open Source Scout Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API keys (per agent — one key per Groq account spreads rate limits)
# Create keys at: https://console.groq.com/keys
# Used by integrations/groq_client.py via core/runtime/agent_profiles.py GROQ_API_KEY_ENV
GROQ_API_KEY_PATHFINDER=<your-groq-api-key-for-pathfinder>
GROQ_API_KEY_TRIAGE_NURSE=<your-groq-api-key-for-triage-nurse>
GROQ_API_KEY_ARCHAEOLOGIST=<your-groq-api-key-for-archaeologist>
GROQ_API_KEY_SENIOR_DEV=<your-groq-api-key-for-senior-dev>
GROQ_API_KEY_TESTING_AGENT=<your-groq-api-key-for-testing-agent>
GROQ_API_KEY_REVIEWER=<your-groq-api-key-for-learning-reviewer>
# Optional fallback if a per-agent key is missing (tests / single-key local dev)
GROQ_API_KEY=<your-groq-api-key-here>

# GitHub Token (Optional, but recommended)
# Without token: 60 requests/hour
# With token: 5000 requests/hour
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=<your-github-token-here>

# Neon Postgres (Required for signup/login)
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
NEON_DATABASE_URL=<your-neon-postgres-connection-string>

# Auth (Required for issuing JWTs)
# Use a long random string in production.
AUTH_JWT_SECRET=<your-jwt-secret>

# GitHub OAuth (optional — enables "Continue with GitHub")
# Create an OAuth App: GitHub → Settings → Developer settings → OAuth Apps
# CLIENT_ID / CLIENT_SECRET are the OAuth App credentials (or use GITHUB_OAUTH_CLIENT_ID / GITHUB_OAUTH_CLIENT_SECRET).
# GITHUB_REDIRECT_URI must match the "Authorization callback URL" in the OAuth App exactly.
# With Vite dev server (proxy /api → backend): use the frontend origin + /api/auth/github/callback
GITHUB_REDIRECT_URI=http://localhost:5173/api/auth/github/callback
FRONTEND_URL=http://localhost:5173
CLIENT_ID=<github-oauth-app-client-id>
CLIENT_SECRET=<github-oauth-app-client-secret>

# Production CORS (required when deployed — comma-separated frontend origins)
# Example: ALLOWED_ORIGINS=https://your-app.up.railway.app,https://www.yourdomain.com
# Also set FRONTEND_URL to your public app URL in production.
# APP_ENV=production disables localhost CORS defaults (Railway sets RAILWAY_ENVIRONMENT automatically).
ALLOWED_ORIGINS=
APP_ENV=development

# Cascadeflow (runtime intelligence — observe | enforce | off)
CASCADEFLOW_MODE=observe
CASCADEFLOW_BUDGET_USD=0.10

# Hindsight (optional — enables agent memory / personalization)
# 1) Sign in: https://ui.hindsight.vectorize.io
# 2) Billing / plans: apply promo code MEMHACK515 there (must be done in the web UI; not configurable here).
# 3) Create or copy an API key from the Hindsight dashboard and paste it below.
# Self-hosted: set HINDSIGHT_API_URL to your instance base URL.
HINDSIGHT_API_URL=https://api.hindsight.vectorize.io
HINDSIGHT_API_KEY=
HINDSIGHT_BANK_PREFIX=scout
